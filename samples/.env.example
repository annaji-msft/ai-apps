# ai-apps samples — environment variables
#
# Copy this file to `.env` (in the same folder) OR run a `setup/` script,
# which will create `.env` automatically.
#
# Every sample reads from `samples/.env`. Per-sample scripts walk up from
# their own folder until they find this file.

# --- Required for every pillar ---------------------------------------------

# Your Azure subscription ID. Get with: az account show --query id -o tsv
AZURE_SUBSCRIPTION_ID=
# Same value, exposed under the name the `aca` CLI reads.
ACA_SUBSCRIPTION=

# --- Sandboxes pillar ------------------------------------------------------

# Resource group that holds the sandbox group. Created by setup if missing.
ACA_RESOURCE_GROUP=ai-apps-samples-rg

# Sandbox group name. Created by setup if missing.
ACA_SANDBOX_GROUP=ai-apps-samples-group

# Azure region for the sandbox group. Use a region from `aca region list`
# or any region listed for Microsoft.App in `az provider show`.
ACA_SANDBOXGROUP_REGION=westus2
# Same value, exposed under the name the `aca` CLI reads.
ACA_REGION=westus2

# --- Container container apps pillar (Phase 4+) ------------------------------------------------

# ACA_ENVIRONMENT_NAME=ai-apps-env
# ACA_LOG_ANALYTICS_WORKSPACE=ai-apps-logs

# --- Connectors pillar (Phase 6+) ------------------------------------------

# COSMOS_ACCOUNT_NAME=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_STORAGE_ACCOUNT=
# KEY_VAULT_NAME=

# --- Triggers pillar (Phase 7+) --------------------------------------------

# EVENT_GRID_TOPIC_ENDPOINT=
# EVENT_GRID_TOPIC_KEY=
# SERVICE_BUS_CONNECTION_STRING=

# --- AI app workloads (Phase 8+) -------------------------------------------

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=

# --- Computer-use scenario (samples/sandboxes/scenarios/07-computer-use) ---

# Azure OpenAI resource hosting a `computer-use-preview` deployment.
# Request access at https://aka.ms/oai/cu if you don't have it yet.
# AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_COMPUTER_USE_DEPLOYMENT=computer-use-preview
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# --- Connectors-triggers scenario ------------------------------------------
# (samples/sandboxes/scenarios/10-connectors-triggers)
#
# Provisions a Microsoft.Web/connectorGateways resource with a
# SystemAssigned managed identity, plus an Office 365 connection on it.
# Both setup flows (python + cli) auto-write the keys below to samples/.env.

# Connector gateway name. Created by setup if missing.
# ACA_CONNECTOR_GATEWAY=ai-apps-samples-gw

# Azure region for the connector gateway. Defaults to ACA_SANDBOXGROUP_REGION
# (set by the sandboxes pillar baseline) so the gateway and sandboxes are
# colocated. Override only if you need a different connector-supported region
# (e.g. brazilsouth, westeurope, uksouth).
# ACA_CONNECTOR_GATEWAY_REGION=

# Office 365 connection name on the gateway.
# ACA_CONNECTOR_CONNECTION=o365-conn

# Gateway's system-assigned managed identity (auto-captured by setup).
# Used to add the gateway MI to a sandbox port's entraId.objectIds so the
# gateway can authenticate to the port.
# ACA_CONNECTOR_GATEWAY_PRINCIPAL_ID=
# ACA_CONNECTOR_GATEWAY_TENANT_ID=

# Office 365 connection's runtime URL (auto-captured by setup). The sandbox
# listener POSTs to {RUNTIME_URL}/v2/Mail to send the outbound report; the
# egress transform rule injects the Bearer token.
# ACA_CONNECTOR_CONNECTION_RUNTIME_URL=

# Sandbox-group's system-assigned managed identity (auto-captured + enabled
# by setup). Used as the principal in the connection's sandbox-acl access
# policy + as the Authorization source for the egress transform rule.
# ACA_SANDBOX_GROUP_PRINCIPAL_ID=

# --- email-to-sandbox sub-scenario (samples/sandboxes/scenarios/10-connectors-triggers/email-to-sandbox)
#
# The listener does minimal stdlib processing (word/line/char counts) on each
# incoming "Feedback" email, then emails an acknowledgment reply back through
# the same Office 365 connection (SendMailV2). No AI keys / no extra runtime
# deps required.

# Recipient for the acknowledgment reply. Defaults to ACA_USER_EMAIL (the
# consenting user) if unset — convenient for round-trip demos to your own inbox.
# TRIAGE_RECIPIENT=triage@contoso.com
