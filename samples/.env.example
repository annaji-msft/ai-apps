# ai-apps samples — environment variables
#
# Copy this file to `.env` (in the same folder) OR run a `setup/` script,
# which will create `.env` automatically.
#
# Every sample reads from `samples/.env`. Per-sample scripts walk up from
# their own folder until they find this file.

# --- Required for every pillar ---------------------------------------------

# Your Azure subscription ID. Get with: az account show --query id -o tsv
AZURE_SUBSCRIPTION_ID=
# Same value, exposed under the name the `aca` CLI reads.
ACA_SUBSCRIPTION=

# --- Sandboxes pillar ------------------------------------------------------

# Resource group that holds the sandbox group. Created by setup if missing.
ACA_RESOURCE_GROUP=ai-apps-samples-rg

# Sandbox group name. Created by setup if missing.
ACA_SANDBOX_GROUP=ai-apps-samples-group

# Azure region for the sandbox group. Use a region from `aca region list`
# or any region listed for Microsoft.App in `az provider show`.
ACA_SANDBOXGROUP_REGION=westus2
# Same value, exposed under the name the `aca` CLI reads.
ACA_REGION=westus2

# --- Apps pillar (Phase 4+) ------------------------------------------------

# ACA_ENVIRONMENT_NAME=ai-apps-env
# ACA_LOG_ANALYTICS_WORKSPACE=ai-apps-logs

# --- Connectors pillar (Phase 6+) ------------------------------------------

# COSMOS_ACCOUNT_NAME=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_STORAGE_ACCOUNT=
# KEY_VAULT_NAME=

# --- Triggers pillar (Phase 7+) --------------------------------------------

# EVENT_GRID_TOPIC_ENDPOINT=
# EVENT_GRID_TOPIC_KEY=
# SERVICE_BUS_CONNECTION_STRING=

# --- AI app workloads (Phase 8+) -------------------------------------------

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=
